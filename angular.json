{
  "$schema": "./node_modules/@angular/cli/lib/config/schema.json",
  "version": 1,
  "newProjectRoot": "projects",
  "projects": {
    "finlink_frontend": {
      "projectType": "application",
      "schematics": {},
      "root": "",
      "sourceRoot": "src",
      "prefix": "app",
      "architect": {
        "build": {
          "builder": "@angular-devkit/build-angular:application",
          "options": {
            "outputPath": "dist/finlink_frontend",
            "index": "src/index.html",
            "browser": "src/main.ts",
            "polyfills": [
              "zone.js"
            ],
            "tsConfig": "tsconfig.app.json",
            "assets": [
              {
                "glob": "**/*",
                "input": "public"
              },
              {
                "glob": "**/*",
                "input": "src/assets",
                "output": "/assets/"
              },
              {
                "glob": "**/*",
                "input": "src/assets/libs/fontawesome/webfonts",
                "output": "/assets/libs/fontawesome/webfonts/"
              },
              {
                "glob": "**/*",
                "input": "src/assets/libs/flaticon/webfonts",
                "output": "/assets/libs/flaticon/webfonts/"
              }
            ],
            "styles": [
              "src/styles.css",
              "src/assets/css/styles.css",
              "src/assets/libs/bootstrap-select/css/bootstrap-select.min.css",
              "src/assets/libs/flatpickr/flatpickr.min.css",
              "src/assets/libs/fontawesome/css/all.min.css",
              "src/assets/libs/datatables/datatables.min.css",
              "src/assets/libs/jsvectormap/jsvectormap.min.css",
              "src/assets/libs/leaflet/leaflet.css",
              "src/assets/libs/swiper/swiper-bundle.min.css",
              "src/assets/libs/flaticon/css/all/all.css",
              "src/assets/libs/flaticon/css/all/all.rounded.css",
              "src/assets/libs/flaticon/css/all/all.straight.css",
              "src/assets/libs/flaticon/css/bold/rounded.css",
              "src/assets/libs/flaticon/css/bold/straight.css",
              "src/assets/libs/flaticon/css/brands/all.css",
              "src/assets/libs/flaticon/css/regular/rounded.css",
              "src/assets/libs/flaticon/css/regular/straight.css",
              "src/assets/libs/flaticon/css/solid/rounded.css",
              "src/assets/libs/flaticon/css/solid/straight.css",
              "src/assets/libs/flaticon/css/thin/rounded.css",
              "src/assets/libs/flaticon/css/thin/straight.css",
              "src/assets/libs/lucide/lucide.css",
              "src/assets/libs/simplebar/simplebar.css",
              "src/assets/libs/node-waves/waves.css",
              "src/assets/libs/tagify/tagify.css"
            ],
            "scripts": [
              "node_modules/jquery/dist/jquery.js",
              "node_modules/bootstrap/dist/js/bootstrap.bundle.js",
              "node_modules/simplebar/dist/simplebar.js",
              "src/assets/libs/flatpickr/flatpickr.min.js",
              "src/assets/libs/datatables/datatables.min.js",
              "src/assets/libs/apexcharts/apexcharts.min.js",
              "src/assets/libs/chartjs/chart.js",
              "src/assets/libs/jsvectormap/jsvectormap.min.js",
              "src/assets/libs/leaflet/leaflet.js",
              "src/assets/libs/swiper/swiper-bundle.min.js",
              "src/assets/libs/sortable/Sortable.min.js",
              "src/assets/libs/tagify/tagify.js",
              "src/assets/js/appSettings.js",
              "src/assets/js/dashboard.js",
              "src/assets/js/datatable.js",
              "src/assets/js/flatpickr.js",
              "src/assets/js/main.js",
              "src/assets/js/snippets.js",
              "src/assets/js/tagify.js",
              "src/assets/js/validation.js"
            ]
          },
          "configurations": {
            "production": {
              "budgets": [
                {
                  "type": "initial",
                  "maximumWarning": "500kB",
                  "maximumError": "1MB"
                },
                {
                  "type": "anyComponentStyle",
                  "maximumWarning": "4kB",
                  "maximumError": "8kB"
                }
              ],
              "outputHashing": "all"
            },
            "development": {
              "optimization": false,
              "extractLicenses": false,
              "sourceMap": true
            }
          },
          "defaultConfiguration": "production"
        },
        "serve": {
          "builder": "@angular-devkit/build-angular:dev-server",
          "options": {
            "proxyConfig": "proxy.conf.json"
          },
          "configurations": {
            "production": {
              "buildTarget": "finlink_frontend:build:production"
            },
            "development": {
              "buildTarget": "finlink_frontend:build:development"
            }
          },
          "defaultConfiguration": "development"
        },
        "extract-i18n": {
          "builder": "@angular-devkit/build-angular:extract-i18n"
        },
        "test": {
          "builder": "@angular-devkit/build-angular:karma",
          "options": {
            "polyfills": [
              "zone.js",
              "zone.js/testing"
            ],
            "tsConfig": "tsconfig.spec.json",
            "assets": [
              {
                "glob": "**/*",
                "input": "public"
              }
            ],
            "styles": [
               "src/styles.css",
              "src/assets/css/styles.css",
              "src/assets/libs/bootstrap-select/css/bootstrap-select.min.css",
              "src/assets/libs/flatpickr/flatpickr.min.css",
              "src/assets/libs/fontawesome/css/all.min.css",
              "src/assets/libs/datatables/datatables.min.css",
              "src/assets/libs/jsvectormap/jsvectormap.min.css",
              "src/assets/libs/leaflet/leaflet.css",
              "src/assets/libs/swiper/swiper-bundle.min.css"
            ],
            "scripts": [
              "node_modules/jquery/dist/jquery.js",
              "node_modules/bootstrap/dist/js/bootstrap.bundle.js",
              "node_modules/simplebar/dist/simplebar.js",
              "src/assets/libs/flatpickr/flatpickr.min.js",
              "src/assets/libs/datatables/datatables.min.js",
              "src/assets/libs/apexcharts/apexcharts.min.js",
              "src/assets/libs/chartjs/chart.js",
              "src/assets/libs/jsvectormap/jsvectormap.min.js",
              "src/assets/libs/leaflet/leaflet.js",
              "src/assets/libs/swiper/swiper-bundle.min.js",
              "src/assets/libs/sortable/Sortable.min.js",
              "src/assets/libs/tagify/tagify.js",
              "src/assets/js/appSettings.js",
              "src/assets/js/dashboard.js",
              "src/assets/js/datatable.js",
              "src/assets/js/flatpickr.js",
              "src/assets/js/main.js",
              "src/assets/js/snippets.js",
              "src/assets/js/tagify.js",
              "src/assets/js/validation.js"
            ]
          }
        }
      }
    }
  },
  "cli": {
    "analytics": false
  }
}
